{
  "expo": {
    "name": "Sangre y Plata Mobile",
    "slug": "la-campania-mobile",
    "version": "0.0.2",
    "orientation": "default",
    "icon": "./assets/images/logo-gaucho-puro.png",
    "scheme": "lacampania",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/logo-gaucho-puro.png"
    },
    "android": {
      "googleServicesFile": "./android/app/google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "la-campania.vercel.app",
              "pathPrefix": "/invitar/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#08140f",
        "foregroundImage": "./assets/images/logo-gaucho-puro.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/logo-gaucho-puro.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jcancelo.lacampaniamobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-gaucho-puro.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08140f",
          "android": {
            "image": "./assets/images/logo-gaucho-puro.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
