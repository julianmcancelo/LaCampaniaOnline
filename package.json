{
  "name": "la-campana",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json servidor/indice.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "build:backend": "tsc --project tsconfig.server.json",
    "start": "node dist/servidor/indice.js",
    "start:backend": "node dist/servidor/backend.js",
    "start:dev": "ts-node --project tsconfig.server.json servidor/indice.ts",
    "lint": "next lint",
    "test": "ts-node --project tsconfig.server.json motor/run-tests.ts",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:android:instalar": "cmd /c \"cd /d apps\\mobile\\android && gradlew.bat installDebug\"",
    "mobile:android:abrir": "cmd /c \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe shell am start -n com.anonymous.lacampaniamobile/.MainActivity\"",
    "mobile:web": "npm --prefix apps/mobile run web",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^11.0.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
